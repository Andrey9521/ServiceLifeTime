@model dynamic 

@{
    ViewData["Title"] = "🌲 «Золота Підкова» — Таверна Пригод";
}

<div class="hero-bg d-flex align-items-center justify-content-center text-center text-white"
     style="background: linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.85)), url('https://i.imgur.com/5CBPh.jpg') no-repeat center center; background-size: cover; min-height: 100vh; position: relative;">

    <div class="container py-5">

        <!-- Заголовок таверни -->
        <div class="mb-5">
            <h1 class="display-1 fw-bold text-warning text-shadow" style="font-family: 'Cinzel', serif;">
                🪵 Позолочина  Підкова 🪵
            </h1>
            <p class="lead fs-3 text-light">Найкраща таверна в усьому королівстві!</p>
            <p class="text-warning">Шинкар <strong>@ViewData["TavernName"]</strong> вітає тебе 🔥</p>
        </div>

        <div class="row g-4">

            <!-- 1. Шинкар — Singleton -->
            <div class="col-lg-4">
                <div class="card h-100 bg-dark border-warning shadow-lg">
                    <div class="card-header bg-warning text-dark text-center fw-bold">
                        👑 ШИНКАР (Singleton)
                    </div>
                    <div class="card-body text-center">
                        <img src="https://i.imgur.com/Ahr1M.jpg" alt="Шинкар" class="img-fluid rounded-circle mb-3" style="max-height: 180px;">
                        <h4 class="text-warning">@ViewData["TavernName"]</h4>
                        <p class="text-light">Один на всю таверну. Пам'ятає <strong>все</strong>.</p>
                        
                        <div class="mt-4 p-3 bg-secondary rounded">
                            <h5>Відвідувачів з моменту відкриття:</h5>
                            <h1 class="display-1 text-danger mb-0">@ViewData["TotalVisitors"]</h1>
                        </div>
                    </div>
                    <div class="card-footer text-white small">
                        Lifetime: <strong>Singleton</strong> — існує поки працює додаток
                    </div>
                </div>
            </div>

            <!-- 2. Візит — Scoped -->
            <div class="col-lg-4">
                <div class="card h-100 bg-dark border-success shadow-lg">
                    <div class="card-header bg-success text-white text-center fw-bold py-3">
                        🛡️ ПОТОЧНИЙ ВІЗИТ (Scoped)
                    </div>
        
                    <div class="card-body d-flex flex-column align-items-center text-center">
            
                        <h5 class="text-success mb-4">
                            Номер візиту: 
                            <span class="fw-bold fs-4">@ViewData["VisitId"]</span>
                        </h5>

                        <h6 class="text-light mb-3">Твоє замовлення в цьому візиті:</h6>
            
                        <ul class="list-group list-group-flush bg-transparent w-100 mb-4">
                            @foreach (var order in (List<string>)ViewData["Orders"] ?? new List<string>())
                            {
                                <li class="list-group-item bg-transparent text-light border-0 py-2">
                                    @order
                                </li>
                            }
                            @if (((List<string>)ViewData["Orders"] ?? new List<string>()).Count == 0)
                            {
                                <li class="list-group-item bg-transparent text-white-50 border-0 py-3 fst-italic">
                                    Поки що нічого не замовлено...
                                </li>
                            }
                        </ul>

                        <div class="mt-auto w-100">
                            <div class="bg-secondary bg-opacity-25 rounded py-3">
                                <h4 class="text-light mb-1">Загальний рахунок</h4>
                                <h2 class="text-danger mb-0">
                                    @ViewData["TotalBill"] <small class="fs-5">золотих</small>
                                </h2>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer text-white-50 small text-center py-3">
                        Lifetime: <strong class="text-success">Scoped</strong> — новий візит на кожен HTTP-запит
                    </div>
                </div>
            </div>

            <!-- 3. Кубик — Transient -->
            <div class="col-lg-4">
                <div class="card h-100 bg-dark border-info shadow-lg">
                    <div class="card-header bg-info text-dark text-center fw-bold">
                        🎲 КУБИК ПРИГОД (Transient)
                    </div>
                    <div class="card-body text-center">
                        <p class="text-info">Кожен кидок — новий кубик!</p>

                        <div class="d-flex justify-content-center gap-3 flex-wrap">
                            <div class="text-center">
                                <h5>d20</h5>
                                <div class="display-1 text-warning fw-bold">@ViewData["DiceRoll20"]</div>
                            </div>
                            <div class="text-center">
                                <h5>d6</h5>
                                <div class="display-1 text-warning fw-bold">@ViewData["DiceRoll6"]</div>
                            </div>
                            <div class="text-center">
                                <h5>d100</h5>
                                <div class="display-1 text-warning fw-bold">@ViewData["DiceRoll100"]</div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <a asp-action="RollDice" class="btn btn-outline-info btn-lg">
                                🎲 Кинути кубик ще раз
                            </a>
                        </div>
                    </div>
                    <div class="card-footer text-white small">
                        Lifetime: <strong>Transient</strong> — новий екземпляр при кожному виклику
                    </div>
                </div>
            </div>

        </div>

        <!-- Легенда внизу -->
        <div class="mt-5 text-light opacity-75 small">
            <p>
                <strong>Пояснення lifetime:</strong><br>
                • <span class="text-warning">Singleton</span> — один на всю таверну (Шинкар)<br>
                • <span class="text-success">Scoped</span> — один на один візит (один HTTP-запит)<br>
                • <span class="text-info">Transient</span> — новий кубик при кожному кидку
            </p>
            <p class="mt-3">Оновлюй сторінку — побачиш, як працює кожен тип сервісу в реальному часі!</p>
        </div>

    </div>
</div>

<style>
    .text-shadow {
        text-shadow: 0 0 15px rgba(0,0,0,0.9);
    }
    .hero-bg::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle at center, transparent 40%, rgba(0,0,0,0.6) 100%);
    }
</style>